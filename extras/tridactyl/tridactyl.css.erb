/* Modes */
.TridactylModenormal {
  background: var(--oasis-mode-normal) !important;
}
.TridactylModehint {
  background: var(--oasis-mode-hint) !important;
}
.TridactylModevisual {
  background: var(--oasis-mode-visual) !important;
}
.TridactylModeinsert,
.TridactylModeinput {
  background: var(--oasis-mode-insert) !important;
}
.TridactylModenmode {
  background: var(--oasis-mode-nmode) !important;
}

#completion {
  border-color: var(--oasis-ui-border);
}

:root #completions .sectionHeader {
  background: var(--oasis-bg-mantle);
  color: var(--oasis-theme-primary);
  text-transform: uppercase;
}

