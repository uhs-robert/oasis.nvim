  "name": "Oasis Luna Light 3",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#33605b",
    "class.declaration": "#33605b",
    "comment": {
      "foreground": "#665d8a",
      "italic": true
    },
    "decorator": "#7f430e",
    "enum": "#33605b",
    "enumMember": "#934c10",
    "function": "#584328",
    "function.declaration": "#584328",
    "interface": "#33605b",
    "interface.declaration": "#33605b",
    "keyword": "#6b5f1a",
    "macro": "#6b392b",
    "method": "#584328",
    "method.declaration": "#584328",
    "namespace": "#853e28",
    "number": "#934c10",
    "operator": "#595428",
    "parameter": "#33632f",
    "property": "#245f78",
    "regexp": "#a1415f",
    "string": "#8f1014",
    "type": "#33605b",
    "typeParameter": "#33605b",
    "variable": "#100e1b",
    "variable.readonly": "#33605b",
    "variable.readonly.defaultLibrary": "#554ec3"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.line.double-slash",
        "comment.block.documentation"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#665d8a"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template"
      ],
      "settings": {
        "foreground": "#8f1014"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#a1415f"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "string.escape"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#a1415f"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#934c10"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.boolean"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#554ec3"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#934c10"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#6b5f1a"
      }
    },
    {
      "scope": [
        "keyword.control.exception",
        "keyword.control.flow",
        "keyword.control.return"
      ],
      "settings": {
        "foreground": "#a61217"
      }
    },
    {
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.other.import",
        "keyword.other.using",
        "meta.import keyword.other"
      ],
      "settings": {
        "foreground": "#853e28"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#595428"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#4b4828"
      }
    },
    {
      "scope": [
        "punctuation.definition.bracket",
        "meta.brace",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#41444c"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#584328"
      }
    },
    {
      "scope": [
        "meta.function-call entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#584328"
      }
    },
    {
      "scope": [
        "support.function",
        "support.function.builtin",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#6f4b1f"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.enum",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#33605b"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#294d48"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameter variable.other"
      ],
      "settings": {
        "foreground": "#33632f"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#731cc5"
      }
    },
    {
      "scope": [
        "support.constant",
        "support.constant.builtin"
      ],
      "settings": {
        "foreground": "#554ec3"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#245f78"
      }
    },
    {
      "scope": [
        "keyword.control.preprocessor",
        "meta.preprocessor",
        "entity.name.function.preprocessor"
      ],
      "settings": {
        "foreground": "#853e28"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag entity.name.tag"
      ],
      "settings": {
        "foreground": "#33605b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#245f78"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#7f430e"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "heading.1",
        "heading.2",
        "heading.3"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#584328"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#7f430e"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#57542f"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "fontStyle": "underline",
        "foreground": "#33605b"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#8f1014"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#595428"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#245f78"
      }
    },
    {
      "scope": [
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": {
        "foreground": "#934c10"
      }
    },
    {
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#245f78"
      }
    }
  ],
  "type": "light"
}