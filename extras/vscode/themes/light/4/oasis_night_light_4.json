  "name": "Oasis Night Light 4",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#274b46",
    "class.declaration": "#274b46",
    "comment": {
      "foreground": "#725346",
      "italic": true
    },
    "decorator": "#504b21",
    "enum": "#274b46",
    "enumMember": "#2f2e2e",
    "function": "#4c4513",
    "function.declaration": "#4c4513",
    "interface": "#274b46",
    "interface.declaration": "#274b46",
    "keyword": "#6f3e12",
    "macro": "#60450a",
    "method": "#4c4513",
    "method.declaration": "#4c4513",
    "namespace": "#60450a",
    "number": "#2f2e2e",
    "operator": "#6f3e12",
    "parameter": "#1c4418",
    "property": "#1e4f64",
    "regexp": "#72374b",
    "string": "#891418",
    "type": "#274b46",
    "typeParameter": "#274b46",
    "variable": "#4a3b28",
    "variable.readonly": "#274b46",
    "variable.readonly.defaultLibrary": "#3e39a7"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.line.double-slash",
        "comment.block.documentation"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#725346"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template"
      ],
      "settings": {
        "foreground": "#891418"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#72374b"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "string.escape"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#72374b"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#2f2e2e"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.boolean"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#3e39a7"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#2f2e2e"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#6f3e12"
      }
    },
    {
      "scope": [
        "keyword.control.exception",
        "keyword.control.flow",
        "keyword.control.return"
      ],
      "settings": {
        "foreground": "#951015"
      }
    },
    {
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.other.import",
        "keyword.other.using",
        "meta.import keyword.other"
      ],
      "settings": {
        "foreground": "#60450a"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#6f3e12"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#703d12"
      }
    },
    {
      "scope": [
        "punctuation.definition.bracket",
        "meta.brace",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#545a64"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#4c4513"
      }
    },
    {
      "scope": [
        "meta.function-call entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#4c4513"
      }
    },
    {
      "scope": [
        "support.function",
        "support.function.builtin",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#534a13"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.enum",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#274b46"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#274b46"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameter variable.other"
      ],
      "settings": {
        "foreground": "#1c4418"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#6600c4"
      }
    },
    {
      "scope": [
        "support.constant",
        "support.constant.builtin"
      ],
      "settings": {
        "foreground": "#3e39a7"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#1e4f64"
      }
    },
    {
      "scope": [
        "keyword.control.preprocessor",
        "meta.preprocessor",
        "entity.name.function.preprocessor"
      ],
      "settings": {
        "foreground": "#60450a"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag entity.name.tag"
      ],
      "settings": {
        "foreground": "#274b46"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#1e4f64"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#504b21"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "heading.1",
        "heading.2",
        "heading.3"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#4c4513"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#504b21"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#683911"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "fontStyle": "underline",
        "foreground": "#274b46"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#891418"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#6f3e12"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#1e4f64"
      }
    },
    {
      "scope": [
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": {
        "foreground": "#2f2e2e"
      }
    },
    {
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#1e4f64"
      }
    }
  ],
  "type": "light"
}