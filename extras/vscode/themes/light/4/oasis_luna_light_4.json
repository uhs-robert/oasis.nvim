  "name": "Oasis Luna Light 4",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#284c48",
    "class.declaration": "#284c48",
    "comment": {
      "foreground": "#5f557f",
      "italic": true
    },
    "decorator": "#743c0d",
    "enum": "#284c48",
    "enumMember": "#313030",
    "function": "#5a4120",
    "function.declaration": "#5a4120",
    "interface": "#284c48",
    "interface.declaration": "#284c48",
    "keyword": "#544c14",
    "macro": "#783925",
    "method": "#5a4120",
    "method.declaration": "#5a4120",
    "namespace": "#783925",
    "number": "#313030",
    "operator": "#514c25",
    "parameter": "#1c4518",
    "property": "#1f5065",
    "regexp": "#7a334b",
    "string": "#8b1418",
    "type": "#284c48",
    "typeParameter": "#284c48",
    "variable": "#42376c",
    "variable.readonly": "#284c48",
    "variable.readonly.defaultLibrary": "#3f3aaa"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.line.double-slash",
        "comment.block.documentation"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#5f557f"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template"
      ],
      "settings": {
        "foreground": "#8b1418"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#7a334b"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "string.escape"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#7a334b"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#313030"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.boolean"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#3f3aaa"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#313030"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#544c14"
      }
    },
    {
      "scope": [
        "keyword.control.exception",
        "keyword.control.flow",
        "keyword.control.return"
      ],
      "settings": {
        "foreground": "#971015"
      }
    },
    {
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.other.import",
        "keyword.other.using",
        "meta.import keyword.other"
      ],
      "settings": {
        "foreground": "#783925"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#514c25"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#504c2a"
      }
    },
    {
      "scope": [
        "punctuation.definition.bracket",
        "meta.brace",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#555c66"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#5a4120"
      }
    },
    {
      "scope": [
        "meta.function-call entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#5a4120"
      }
    },
    {
      "scope": [
        "support.function",
        "support.function.builtin",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#694313"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.enum",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#284c48"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#284c48"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameter variable.other"
      ],
      "settings": {
        "foreground": "#1c4518"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#6700c7"
      }
    },
    {
      "scope": [
        "support.constant",
        "support.constant.builtin"
      ],
      "settings": {
        "foreground": "#3f3aaa"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#1f5065"
      }
    },
    {
      "scope": [
        "keyword.control.preprocessor",
        "meta.preprocessor",
        "entity.name.function.preprocessor"
      ],
      "settings": {
        "foreground": "#783925"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag entity.name.tag"
      ],
      "settings": {
        "foreground": "#284c48"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#1f5065"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#743c0d"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "heading.1",
        "heading.2",
        "heading.3"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#5a4120"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#743c0d"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#4b4627"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "fontStyle": "underline",
        "foreground": "#284c48"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#8b1418"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#514c25"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#1f5065"
      }
    },
    {
      "scope": [
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": {
        "foreground": "#313030"
      }
    },
    {
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#1f5065"
      }
    }
  ],
  "type": "light"
}