  "name": "Oasis Scorpion Light 5",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#2a4f4b",
    "class.declaration": "#2a4f4b",
    "comment": {
      "foreground": "#644e49",
      "italic": true
    },
    "decorator": "#68360b",
    "enum": "#2a4f4b",
    "enumMember": "#7b3e0d",
    "function": "#44341f",
    "function.declaration": "#44341f",
    "interface": "#2a4f4b",
    "interface.declaration": "#2a4f4b",
    "keyword": "#585015",
    "macro": "#532c21",
    "method": "#44341f",
    "method.declaration": "#44341f",
    "namespace": "#6b3320",
    "number": "#7b3e0d",
    "operator": "#484321",
    "parameter": "#2a5126",
    "property": "#1d4e62",
    "regexp": "#883550",
    "string": "#700c10",
    "type": "#2a4f4b",
    "typeParameter": "#2a4f4b",
    "variable": "#191210",
    "variable.readonly": "#2a4f4b",
    "variable.readonly.defaultLibrary": "#433db3"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.line.double-slash",
        "comment.block.documentation"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#644e49"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template"
      ],
      "settings": {
        "foreground": "#700c10"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#883550"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "string.escape"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#883550"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#7b3e0d"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.boolean"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#433db3"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#7b3e0d"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#585015"
      }
    },
    {
      "scope": [
        "keyword.control.exception",
        "keyword.control.flow",
        "keyword.control.return"
      ],
      "settings": {
        "foreground": "#880f14"
      }
    },
    {
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.other.import",
        "keyword.other.using",
        "meta.import keyword.other"
      ],
      "settings": {
        "foreground": "#6b3320"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#484321"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#3a371f"
      }
    },
    {
      "scope": [
        "punctuation.definition.bracket",
        "meta.brace",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#313439"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#44341f"
      }
    },
    {
      "scope": [
        "meta.function-call entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#44341f"
      }
    },
    {
      "scope": [
        "support.function",
        "support.function.builtin",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#5a3d19"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.enum",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#2a4f4b"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#1f3c38"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameter variable.other"
      ],
      "settings": {
        "foreground": "#2a5126"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#5e17a2"
      }
    },
    {
      "scope": [
        "support.constant",
        "support.constant.builtin"
      ],
      "settings": {
        "foreground": "#433db3"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#1d4e62"
      }
    },
    {
      "scope": [
        "keyword.control.preprocessor",
        "meta.preprocessor",
        "entity.name.function.preprocessor"
      ],
      "settings": {
        "foreground": "#6b3320"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag entity.name.tag"
      ],
      "settings": {
        "foreground": "#2a4f4b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#1d4e62"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#68360b"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "heading.1",
        "heading.2",
        "heading.3"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#44341f"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#68360b"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#474426"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "fontStyle": "underline",
        "foreground": "#2a4f4b"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#700c10"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#484321"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#1d4e62"
      }
    },
    {
      "scope": [
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": {
        "foreground": "#7b3e0d"
      }
    },
    {
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#1d4e62"
      }
    }
  ],
  "type": "light"
}