  "name": "Oasis Lagoon Light 5",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#305b55",
    "class.declaration": "#305b55",
    "comment": {
      "foreground": "#476272",
      "italic": true
    },
    "decorator": "#793f0d",
    "enum": "#305b55",
    "enumMember": "#8d470f",
    "function": "#573d1c",
    "function.declaration": "#573d1c",
    "interface": "#305b55",
    "interface.declaration": "#305b55",
    "keyword": "#135c9d",
    "macro": "#464326",
    "method": "#573d1c",
    "method.declaration": "#573d1c",
    "namespace": "#554f23",
    "number": "#8d470f",
    "operator": "#104d97",
    "parameter": "#315e2c",
    "property": "#225a70",
    "regexp": "#93425e",
    "string": "#860f13",
    "type": "#305b55",
    "typeParameter": "#305b55",
    "variable": "#0e131b",
    "variable.readonly": "#305b55",
    "variable.readonly.defaultLibrary": "#4f49c1"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.line.double-slash",
        "comment.block.documentation"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#476272"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template"
      ],
      "settings": {
        "foreground": "#860f13"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#93425e"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "string.escape"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#93425e"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#8d470f"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.boolean"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#4f49c1"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#8d470f"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#135c9d"
      }
    },
    {
      "scope": [
        "keyword.control.exception",
        "keyword.control.flow",
        "keyword.control.return"
      ],
      "settings": {
        "foreground": "#9d1117"
      }
    },
    {
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.other.import",
        "keyword.other.using",
        "meta.import keyword.other"
      ],
      "settings": {
        "foreground": "#554f23"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#104d97"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#0e4181"
      }
    },
    {
      "scope": [
        "punctuation.definition.bracket",
        "meta.brace",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#3c4046"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#573d1c"
      }
    },
    {
      "scope": [
        "meta.function-call entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#573d1c"
      }
    },
    {
      "scope": [
        "support.function",
        "support.function.builtin",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#69471d"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.enum",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#305b55"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#264844"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameter variable.other"
      ],
      "settings": {
        "foreground": "#315e2c"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#6d1abc"
      }
    },
    {
      "scope": [
        "support.constant",
        "support.constant.builtin"
      ],
      "settings": {
        "foreground": "#4f49c1"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#225a70"
      }
    },
    {
      "scope": [
        "keyword.control.preprocessor",
        "meta.preprocessor",
        "entity.name.function.preprocessor"
      ],
      "settings": {
        "foreground": "#554f23"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag entity.name.tag"
      ],
      "settings": {
        "foreground": "#305b55"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#225a70"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#793f0d"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "heading.1",
        "heading.2",
        "heading.3"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#573d1c"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#793f0d"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#115088"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "fontStyle": "underline",
        "foreground": "#305b55"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#860f13"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#104d97"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#225a70"
      }
    },
    {
      "scope": [
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": {
        "foreground": "#8d470f"
      }
    },
    {
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#225a70"
      }
    }
  ],
  "type": "light"
}